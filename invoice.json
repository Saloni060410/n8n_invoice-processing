    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawText =\n$json.candidates?.[0]?.content?.parts?.[0]?.text || \"\";\n\nlet xmlText = rawText\n  .replace(/```xml/gi, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nif (!xmlText.startsWith(\"<invoice>\")) {\n  throw new Error(\"Gemini did not return valid XML\");\n}\n\nreturn {\n  json: {\n    xmlString: xmlText,\n    rawGeminiResponse: rawText\n  }\n};"
      },
