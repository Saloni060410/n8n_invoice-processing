    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\n// Get binary keys\nconst binaries = item.binary || {};\nconst keys = Object.keys(binaries);\n\n// Find attachment\nconst fileKey = keys.find(k => k.startsWith(\"attachment_\"));\n\nif (!fileKey) {\n  throw new Error(\"No attachment found\");\n}\n\nconst file = binaries[fileKey];\n\n// Convert binary buffer to base64\nconst base64Data = await this.helpers.getBinaryDataBuffer(0, fileKey)\n  .then(buffer => buffer.toString('base64'));\n\nreturn {\n  json: {\n    base64Data,\n    mimeType: file.mimeType,\n    fileName: file.fileName\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        176
      ],
      "id": "c992d0d9-5663-4857-8d5e-af766b3e1859",
      "name": "Convert to base64"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const base64Data = $json.base64Data;\nconst mimeType = $json.mimeType;\nconst GEMINI_API_KEY = 'AIzaSyB3237Y0jcjNsbYZUvXC8yVnsImKjAzOIo';\n\nconst systemPrompt = `\nYou are an invoice data extraction assistant.\nAnalyse the provided invoice document and extract ALL of the following fields.\n\nReturn ONLY a valid XML block — no explanation, no markdown, no extra text.\n\nRequired XML structure:\n<invoice>\n<vendor_name></vendor_name>\n<vendor_address></vendor_address>\n<vendor_email></vendor_email>\n<invoice_number></invoice_number>\n<invoice_date></invoice_date> <!-- Format: YYYY-MM-DD -->\n<due_date></due_date> <!-- Format: YYYY-MM-DD -->\n<currency></currency> <!-- ISO code e.g. USD, INR, GBP -->\n<subtotal></subtotal>\n<tax_amount></tax_amount>\n<total_amount></total_amount>\n<line_items>\n<item>\n<description></description>\n<quantity></quantity>\n<unit_price></unit_price>\n<line_total></line_total>\n</item>\n</line_items>\n<payment_terms></payment_terms>\n<bank_details></bank_details>\n</invoice>\n\nIf a field is not found, leave the tag empty. Do not omit tags.\n`;\n\nconst payload = {\ncontents: [{\nparts: [\n{ text: systemPrompt },\n{ inline_data: { mime_type: mimeType, data: base64Data } }]\n}],\ngenerationConfig: {\n  \ntemperature: 0.1, // Low temperature = deterministic, consistent output\nmaxOutputTokens: 2048,\n  \n}\n};\n\nreturn {\n  json:\n  { payload, \n    apiKey: GEMINI_API_KEY\n  } \n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1056,
        176
      ],
