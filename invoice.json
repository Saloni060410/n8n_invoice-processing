        "jsCode": "const contacts = $json.contacts || [];\n\nconst orgId = $('Map Invoice to Zoho Schema').item.json.orgId;\nconst payload = $('Map Invoice to Zoho Schema').item.json.zohoBillPayload;\n\nlet vendorId;\n\nif (contacts.length > 0) {\n// Vendor found — use existing ID\nvendorId = contacts[0].contact_id;\n} else {\n// Vendor not found — will need to create (set flag for next node)\nvendorId = null;\n}\n\nreturn { \n  json: \n  {vendorId, payload, orgId, needsCreation: vendorId === null \n  } \n};"
