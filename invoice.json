    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const inv = $json.invoice;\nconst orgId = \"60070563462\";\n\n// Helper: clean numeric string → float\nconst toFloat = (s) => parseFloat(String(s).replace(/[^0-9.]/g, '')) || 0;\n// Map line items (handle single item vs array)\nconst rawItems = Array.isArray(inv.line_items?.item)\n? inv.line_items.item\n: [inv.line_items?.item].filter(Boolean);\n\nconst lineItems = rawItems.map(item => ({\ndescription: item.description || 'Service',\nquantity: toFloat(item.quantity) || 1,\nrate: toFloat(item.unit_price),\nitem_total: toFloat(item.line_total),\n}));\n\nconst zohoBillPayload = {\nvendor_name: inv.vendor_name,\nbill_number: inv.invoice_number,\ndate: inv.invoice_date, // YYYY-MM-DD\ndue_date: inv.due_date,\ncurrency_code: inv.currency || 'USD',\nsub_total: toFloat(inv.subtotal),\ntax_total: toFloat(inv.tax_amount),\ntotal: toFloat(inv.total_amount),\nline_items: lineItems,\nnotes: `Auto-imported via n8n on ${new Date().toISOString()}`,\n};\n\nreturn { json: { zohoBillPayload, orgId }};"
      },
